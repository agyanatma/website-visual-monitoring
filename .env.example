# MySQL connection string
DATABASE_URL=mysql://user:password@localhost:3306/website_visual_monitoring

# Dashboard auth
ADMIN_USERNAME=admin
# Preferred: sha256 hash of the admin password
ADMIN_PASSWORD_HASH=
SESSION_SECRET=replace-with-at-least-32-random-characters

# Alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_ALERTS_PER_MINUTE=5

# AI fallback visual review
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it

# Monitoring defaults
CHECK_CADENCE_MINUTES=60
MAX_CONCURRENT_CHECKS=5
NAVIGATION_TIMEOUT_MS=30000
TOTAL_CHECK_TIMEOUT_MS=45000
STABILIZATION_DELAY_MS=2000
CONFIRMATION_RETRY_DELAY_MS=60000
VIEWPORT_WIDTH=390
VIEWPORT_HEIGHT=844
